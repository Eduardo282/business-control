{
  "name": "business-control",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "test:unit": "node --test shared/tests/quotePricingRules.test.js shared/tests/quoteItems.test.js",
    "test:integration": "pnpm --dir backend test",
    "test:e2e": "playwright test",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "build:frontend": "pnpm --dir frontend build",
    "build": "pnpm run build:frontend",
    "lint": "echo \"Configure ESLint or Biome for linting\"",
    "format": "echo \"Configure Prettier or Biome for formatting\"",
    "scan:front": "nuclei -u http://192.168.100.4:5173",
    "scan:back": "nuclei -u http://127.0.0.1:4000",
    "scan:all": "nuclei -u http://192.168.100.4:5173 -u http://127.0.0.1:4000",
    "scan:graphql": "nuclei -u http://127.0.0.1:4000/graphql -tags graphql"
  },

  "devDependencies": { 
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0"
  }
}
